{
  "name": "ai-qe-agent",
  "version": "1.0.0",
  "description": "AI-powered QE Agent that writes, runs, self-heals, and reports E2E automation tests using Playwright + Claude AI",
  "main": "dist/cli/index.js",
  "bin": {
    "ai-qe": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/cli/index.ts",
    "generate": "ts-node src/cli/index.ts generate",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "heal": "ts-node src/cli/index.ts heal",
    "report": "ts-node src/cli/index.ts report",
    "dev": "ts-node-dev --respawn src/cli/index.ts",
    "dev-gen": "ts-node src/cli/index.ts dev-gen",
    "manual-tests": "ts-node src/cli/index.ts manual-tests",
    "qa-review": "ts-node src/cli/index.ts qa-review",
    "gen-automation": "ts-node src/cli/index.ts gen-automation",
    "pipeline": "ts-node src/cli/index.ts pipeline",
    "watch:changes": "ts-node src/cli/index.ts watch",
    "review-queue": "ts-node src/cli/index.ts review-queue",
    "demo": "tsc && node dist/cli/index.js demo",
    "demo:part1": "tsc && node dist/cli/index.js demo --part 1",
    "demo:part2": "tsc && node dist/cli/index.js demo --part 2",
    "demo:part3": "tsc && node dist/cli/index.js demo --part 3",
    "demo:part4": "tsc && node dist/cli/index.js demo --part 4",
    "demo:self-heal": "tsc && node dist/cli/index.js demo --part 3",
    "mobile-test": "ts-node src/cli/index.ts mobile-test",
    "mobile-test:url": "ts-node src/cli/index.ts mobile-test --url http://localhost:3000",
    "mobile-test:all-scenarios": "ts-node src/cli/index.ts mobile-test --url http://localhost:3000 --scenarios layout,navigation,touch,orientation,network,performance,accessibility,pwa,forms,media",
    "mobile-test:list": "ts-node src/cli/index.ts mobile-test --list-devices"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@playwright/test": "^1.49.0",
    "axios": "^1.7.9",
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^8.2.10",
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  },
  "keywords": ["ai", "qe", "automation", "playwright", "e2e", "testing", "self-healing"],
  "author": "AI QE Agent",
  "license": "MIT"
}
